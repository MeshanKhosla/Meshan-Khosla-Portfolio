---
---

<div class="search-box relative">
  <div class="relative">
    <svg
      class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-charcoal-muted dark:text-sand-muted pointer-events-none"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      type="text"
      class="search-input w-full pl-10 pr-10 py-3 rounded-lg
             bg-cream-50 dark:bg-ink-light
             border border-cream-300 dark:border-ink-lighter
             text-charcoal dark:text-sand
             placeholder:text-charcoal-muted dark:placeholder:text-sand-muted
             focus:outline-none focus:ring-2 focus:ring-accent/50 dark:focus:ring-accent-light/50
             focus:border-accent dark:focus:border-accent-light
             transition-colors"
      placeholder="Filter posts..."
      autocomplete="off"
    />
    <!-- Clear button -->
    <button
      type="button"
      class="search-clear absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 
             text-charcoal-muted dark:text-sand-muted hover:text-charcoal dark:hover:text-sand
             hidden"
      aria-label="Clear search"
    >
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  
  <!-- Results count -->
  <div class="search-status mt-3 text-sm text-charcoal-muted dark:text-sand-muted hidden">
    <span class="results-count"></span>
  </div>
</div>

<script>
  interface SearchPost {
    slug: string;
    title: string;
    description: string;
    pubDate: string;
    image: { src: string; srcset: string } | null;
  }

  class SearchBoxComponent {
    private container: HTMLElement;
    private input: HTMLInputElement;
    private clearBtn: HTMLElement;
    private statusEl: HTMLElement;
    private resultsCount: HTMLElement;
    private debounceTimer: number | null = null;
    private searchIndex: Promise<SearchPost[]> | null = null;

    constructor(container: HTMLElement) {
      this.container = container;
      this.input = container.querySelector('.search-input') as HTMLInputElement;
      this.clearBtn = container.querySelector('.search-clear') as HTMLElement;
      this.statusEl = container.querySelector('.search-status') as HTMLElement;
      this.resultsCount = container.querySelector('.results-count') as HTMLElement;
      
      this.init();
    }

    init() {
      this.input.addEventListener('input', () => this.handleInput());
      this.input.addEventListener('keydown', (e) => this.handleKeydown(e));
      this.clearBtn?.addEventListener('click', () => this.clearSearch());
    }

    handleInput() {
      if (this.debounceTimer) {
        clearTimeout(this.debounceTimer);
      }

      this.debounceTimer = window.setTimeout(async () => {
        const query = this.input.value.trim().toLowerCase();
        
        // Show/hide clear button
        if (query.length > 0) {
          this.clearBtn?.classList.remove('hidden');
        } else {
          this.clearBtn?.classList.add('hidden');
        }

        const postsGrid = document.querySelector('[data-posts-grid]') as HTMLElement | null;
        const searchResults = document.querySelector('[data-search-results]') as HTMLElement | null;
        const pagination = document.querySelector('[data-pagination]');
        
        if (query.length === 0) {
          postsGrid?.classList.remove('hidden');
          searchResults?.classList.add('hidden');
          searchResults?.classList.remove('grid');
          searchResults?.replaceChildren();
          if (pagination) (pagination as HTMLElement).style.display = '';
          this.statusEl?.classList.add('hidden');
          return;
        }

        postsGrid?.classList.add('hidden');
        searchResults?.classList.remove('hidden');
        searchResults?.classList.add('grid');
        if (pagination) (pagination as HTMLElement).style.display = 'none';
        this.statusEl?.classList.remove('hidden');
        this.resultsCount.textContent = 'Searching all posts…';

        try {
          this.searchIndex ||= fetch('/blog/search-index.json').then((response) => {
            if (!response.ok) throw new Error(`Search index request failed: ${response.status}`);
            return response.json() as Promise<SearchPost[]>;
          });

          const posts = await this.searchIndex;
          if (query !== this.input.value.trim().toLowerCase()) return;

          const matches = posts.filter((post) =>
            post.title.toLowerCase().includes(query) ||
            post.description.toLowerCase().includes(query) ||
            post.slug.toLowerCase().includes(query)
          );

          if (searchResults) this.renderResults(searchResults, matches);

          if (matches.length === 0) {
            this.resultsCount.textContent = `No posts found for "${this.input.value}"`;
          } else {
            this.resultsCount.textContent = `Showing ${matches.length} ${matches.length === 1 ? 'post' : 'posts'}`;
          }
        } catch {
          this.searchIndex = null;
          this.resultsCount.textContent = 'Search is temporarily unavailable. Please try again.';
        }
      }, 100);
    }

    renderResults(container: HTMLElement, posts: SearchPost[]) {
      const fragment = document.createDocumentFragment();

      posts.forEach((post) => {
        const article = document.createElement('article');
        article.className = 'group relative';

        const link = document.createElement('a');
        link.href = `/blog/${post.slug}/`;
        link.className = 'block h-full';

        const card = document.createElement('div');
        card.className = 'card card-hover h-full flex flex-col overflow-hidden';

        if (post.image) {
          const imageWrap = document.createElement('div');
          imageWrap.className = '-mx-6 -mt-6 mb-4 overflow-hidden bg-cream-200 dark:bg-ink-lighter';
          const ratio = document.createElement('div');
          ratio.className = 'aspect-[16/10] overflow-hidden';
          const image = document.createElement('img');
          image.src = post.image.src;
          image.srcset = post.image.srcset;
          image.sizes = '(min-width: 1024px) calc((100vw - 17rem) / 3), (min-width: 768px) 50vw, 100vw';
          image.alt = post.title;
          image.width = 800;
          image.height = 500;
          image.loading = 'lazy';
          image.decoding = 'async';
          image.className = 'w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105';
          ratio.append(image);
          imageWrap.append(ratio);
          card.append(imageWrap);
        }

        const copy = document.createElement('div');
        copy.className = 'flex-1 flex flex-col';
        const meta = document.createElement('p');
        meta.className = 'text-xs text-charcoal-muted dark:text-sand-muted mb-2';
        meta.textContent = new Date(post.pubDate).toLocaleDateString('en-US', {
          year: 'numeric', month: 'short', day: 'numeric',
        });
        const heading = document.createElement('h3');
        heading.className = 'font-serif text-lg font-semibold text-charcoal dark:text-sand group-hover:text-accent dark:group-hover:text-accent-light transition-colors line-clamp-2 mb-2';
        heading.textContent = post.title;
        const description = document.createElement('p');
        description.className = 'text-sm text-charcoal-muted dark:text-sand-muted line-clamp-3 flex-1';
        description.textContent = post.description;
        copy.append(meta, heading, description);
        card.append(copy);
        link.append(card);
        article.append(link);
        fragment.append(article);
      });

      container.replaceChildren(fragment);
    }

    handleKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape') {
        this.clearSearch();
        this.input.blur();
      }
    }

    clearSearch() {
      this.input.value = '';
      this.clearBtn?.classList.add('hidden');
      this.statusEl?.classList.add('hidden');
      
      const postsGrid = document.querySelector('[data-posts-grid]') as HTMLElement | null;
      const searchResults = document.querySelector('[data-search-results]') as HTMLElement | null;
      postsGrid?.classList.remove('hidden');
      searchResults?.classList.add('hidden');
      searchResults?.classList.remove('grid');
      searchResults?.replaceChildren();
      
      // Show pagination
      const pagination = document.querySelector('[data-pagination]');
      if (pagination) (pagination as HTMLElement).style.display = '';
    }
  }

  // Initialize all search boxes
  function initSearchBoxes() {
    document.querySelectorAll('.search-box').forEach(container => {
      new SearchBoxComponent(container as HTMLElement);
    });
  }

  // Run on load
  initSearchBoxes();
</script>
