---
import ShippedVisual from './ShippedVisual.astro';

interface Props {
  caseStudy: {
    title: string;
    company: string;
    visual: 'chart' | 'tooltip' | 'controls' | 'pipeline' | 'map' | 'lock' | 'batch' | 'python' | 'docs' | 'queue';
    summary: string;
    links: ReadonlyArray<{ label: string; href: string }>;
  };
}

const { caseStudy } = Astro.props;
const coverAccent = caseStudy.company.includes('Upstash')
  ? '#197a52'
  : caseStudy.company.includes('Berkeley')
    ? '#b87918'
    : '#2f6f9f';
---

<article class="p-6 lg:p-12 max-w-3xl mx-auto">
  <a href="/shipped" class="inline-flex items-center gap-2 text-sm text-charcoal-muted dark:text-sand-muted hover:text-accent dark:hover:text-accent-light transition-colors mb-8">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
    Back to shipped work
  </a>

  <header class="mb-10">
    <div class="case-cover mb-8" style={`--lane-accent: ${coverAccent};`}><ShippedVisual kind={caseStudy.visual} size="cover" /></div>
    <p class="text-sm text-accent dark:text-accent-light font-medium mb-4 tracking-wide uppercase">{caseStudy.company}</p>
    <h1 class="font-serif text-4xl md:text-5xl font-semibold text-balance leading-tight">{caseStudy.title}</h1>
    <p class="mt-5 text-lg leading-relaxed text-charcoal-muted dark:text-sand-muted">{caseStudy.summary}</p>
    {caseStudy.links.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-3">
        {caseStudy.links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn btn-ghost border border-cream-300 dark:border-ink-lighter">{link.label}</a>
        ))}
      </div>
    )}
  </header>

  <div class="case-body prose prose-lg dark:prose-invert max-w-none">
    <slot />
  </div>
</article>

<style>
  .case-cover { min-height: 18rem; overflow: hidden; border: 1px solid rgb(232 224 208); border-radius: 0.5rem; }
  .case-cover :global(.shipped-visual) { min-height: 18rem; }
  :global(.dark) .case-cover { border-color: rgb(37 36 34); }

  .case-body :global(img) { display: block; width: 100%; height: auto; margin: 2rem 0 0.65rem; border: 1px solid rgb(232 224 208); border-radius: 0.35rem; }
  .case-body :global(p.image-source) { margin: 0 0 2rem; color: rgb(98 96 91); font-size: 0.75rem; line-height: 1.45; }
  .case-body :global(p.image-source a) { color: inherit; text-decoration: underline; text-underline-offset: 0.2em; }
  :global(.dark) .case-body :global(img) { border-color: rgb(47 46 43); }
  :global(.dark) .case-body :global(p.image-source) { color: rgb(153 149 141); }
</style>
