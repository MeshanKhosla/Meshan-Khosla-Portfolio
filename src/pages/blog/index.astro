---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import GridCard from '../../components/GridCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import Pagination from '../../components/Pagination.astro';
import { getBlogImageSources } from '../../utils/blog-image';

// Get all blog posts sorted by date
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const pageSize = 9;
const posts = allPosts.slice(0, pageSize);
const totalPages = Math.ceil(allPosts.length / pageSize);

// Format date helper
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

---

<Layout title="Blog" description="Technical blog posts about distributed systems, software engineering, and more.">
  <div class="p-6 lg:p-12">
    <!-- Header -->
    <header class="max-w-4xl mb-10">
      <h1 class="font-serif text-3xl lg:text-4xl font-semibold mb-4">Blog</h1>
      <p class="text-charcoal-muted dark:text-sand-muted text-balance">
        Thoughts on distributed systems, software engineering, and things I'm learning.
      </p>
    </header>

    <!-- Search / Filter -->
    <div class="max-w-md mb-10">
      <SearchBox />
    </div>

    <!-- Posts Grid -->
    <div data-posts-grid class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      {posts.map((post) => (
        <GridCard
          title={post.data.title}
          description={post.data.description}
          url={`/blog/${post.id}/`}
          image={getBlogImageSources(post.data.heroImage).src}
          imageSrcset={getBlogImageSources(post.data.heroImage).srcset}
          imageSizes="(min-width: 1024px) calc((100vw - 17rem) / 3), (min-width: 768px) 50vw, 100vw"
          meta={formatDate(post.data.pubDate)}
          slug={post.id}
        />
      ))}
    </div>

    <div data-search-results class="hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10" aria-live="polite"></div>

    <div data-pagination>
      <Pagination currentPage={1} totalPages={totalPages} baseUrl="/blog/" />
    </div>
  </div>
</Layout>
